# Created by Vercel CLI
BLOB_READ_WRITE_TOKEN=vercel_blob_write_token
GOOGLE_PLACES_API_KEY=google_places_api_key
GOOGLE_PLACE_ID=google_place_id
MONGODB_URI=mongodb_uri
NEXT_PUBLIC_PAYLOAD_URL=http://localhost:3000
PAYLOAD_SECRET=payload_secret
VERCEL_OIDC_TOKEN=vercel_oidc_token

# Rate Limiting (Upstash Redis)
# Get from: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=your-upstash-redis-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# Email Configuration (Resend)
# Get API key from: https://resend.com/
RESEND_API_KEY=your-resend-api-key
FROM_EMAIL=quotes@prestigeautobody.com
SHOP_EMAIL=quotes@prestigeautobody.com

# Security
# Generate with: openssl rand -hex 32
IP_HASH_SALT=your-secret-salt-for-ip-hashing

# n8n Blog Automation (Required for content pipeline)
# Generate with: openssl rand -hex 32
N8N_WEBHOOK_SECRET=your-n8n-webhook-secret

# ISR Revalidation (Required for cache invalidation)
# Generate with: openssl rand -hex 32
REVALIDATE_SECRET=your-revalidate-secret

# Google Analytics 4 (Optional — analytics, web-vitals, and consent banner stay
# fully inactive when this is unset; nothing about the site changes.)
# Get from: https://analytics.google.com → Admin → Data Streams → Web → Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
