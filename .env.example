# Payload CMS Environment Variables
# Generate a random secret: openssl rand -hex 32
PAYLOAD_SECRET=your-payload-secret-key-here

# MongoDB connection string
# Local: mongodb://127.0.0.1:27017/prestigeautobody
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/prestigeautobody
MONGODB_URI=mongodb://127.0.0.1:27017/prestigeautobody

# Vercel Blob Storage (optional - for media uploads in production)
# Get token from: https://vercel.com/dashboard/stores
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token-here

# Next.js
NEXT_PUBLIC_PAYLOAD_URL=http://localhost:3000
